{
    "name": "refactoring-avanzado/php",
    "description": "Curso de Refactoring Avanzado - Versión PHP",
    "type": "project",
    "license": "ISC",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "Calisthenics\\": "src/calisthenics-exercises/",
            "CodeSmells\\": "src/code-smells/",
            "Refactoring\\": "src/refactoring/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "XDEBUG_MODE=coverage phpunit --coverage-html coverage --coverage-text --coverage-clover coverage/clover.xml",
        "phpstan": "phpstan analyse src tests --level=8",
        "cs": "phpcs src tests --standard=PSR12",
        "cs:fix": "phpcbf src tests --standard=PSR12"
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
